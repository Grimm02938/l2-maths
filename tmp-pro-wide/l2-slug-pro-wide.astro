---
import Base from '../../layouts/Base.astro';
import { contenuFinalL2 } from '../../data/contenu-final-l2';

const hiddenSections = new Set(contenuFinalL2.rules.hiddenSections);
const displayOrder = contenuFinalL2.rules.displayOrder.filter(
  (section) => !hiddenSections.has(section) && section !== 'À vérifier'
);

export function getStaticPaths() {
  const hiddenSectionsForPaths = new Set(contenuFinalL2.rules.hiddenSections);

  const visibleSubjects = new Set(
    contenuFinalL2.documents
      .filter((doc) => !doc.hidden && !hiddenSectionsForPaths.has(doc.section))
      .map((doc) => doc.subject)
  );

  return Object.entries(contenuFinalL2.subjects)
    .filter(([slug]) => visibleSubjects.has(slug))
    .map(([slug, subject]) => ({
      params: { slug },
      props: {
        subject: {
          slug,
          title: subject.title,
          description: subject.subtitle,
          semester: subject.semester,
        },
      },
    }));
}

const { subject } = Astro.props;

const subjectDocs = contenuFinalL2.documents.filter(
  (doc) => doc.subject === subject.slug && !doc.hidden && !hiddenSections.has(doc.section)
);

const sections = displayOrder
  .map((section) => ({
    title: section,
    docs: subjectDocs
      .filter((doc) => doc.section === section)
      .sort((a, b) => {
        if (a.subjectOrder !== b.subjectOrder) return a.subjectOrder - b.subjectOrder;
        return a.displayTitle.localeCompare(b.displayTitle, 'fr', { numeric: true });
      }),
  }))
  .filter((section) => section.docs.length > 0);

const totalDocuments = sections.reduce((sum, section) => sum + section.docs.length, 0);

function detailFor(section, doc) {
  const title = doc.displayTitle.toLowerCase();

  if (section === 'Cours') {
    if (title.includes('formulaire')) return 'référence';
    if (title.includes('poly')) return 'polycopié';
    if (title.includes('notes')) return 'notes';
    return 'cours';
  }

  if (section === 'TD') return 'exercices';
  if (section === 'Tests / CC') return 'contrôle';
  if (section === 'Partiels') return 'sujet';
  if (section === 'Examens') return 'sujet';
  if (section.includes('Corrigés')) return 'correction';

  return doc.extension?.toUpperCase() ?? 'PDF';
}
---
<Base title={`${subject.title} — Archives mathématiques`} description={subject.description}>
  <main class="course-page">
    <nav class="breadcrumb" aria-label="Fil d’Ariane">
      <a href="/">Accueil</a>
      <span>/</span>
      <a href="/#licence-2">Licence 2</a>
      <span>/</span>
      <span>{subject.title}</span>
    </nav>

    <header class="course-hero">
      <div class="course-title">
        <p class="semester">{subject.semester}</p>
        <h1>{subject.title}</h1>
        <p>{subject.description}</p>
      </div>

      <aside class="course-meta" aria-label="Résumé">
        <div>
          <strong>{totalDocuments}</strong>
          <span>documents</span>
        </div>
        <div>
          <strong>{sections.length}</strong>
          <span>sections</span>
        </div>
      </aside>
    </header>

    <section class="archive-list" aria-label="Documents">
      {sections.map((section, index) => (
        <article class="archive-section">
          <header class="section-head">
            <span class="section-number">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h2>{section.title}</h2>
              <p>{section.docs.length} document{section.docs.length > 1 ? 's' : ''}</p>
            </div>
          </header>

          <div class="document-list">
            {section.docs.map((doc) => (
              <a class="document-row" href={doc.publicHref} target="_blank" rel="noreferrer">
                <span class="document-title">{doc.displayTitle}</span>
                <span class="document-detail">{detailFor(section.title, doc)}</span>
              </a>
            ))}
          </div>
        </article>
      ))}
    </section>
  </main>
</Base>

<style>
  :global(body) {
    background:
      linear-gradient(rgba(125, 96, 54, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(125, 96, 54, 0.025) 1px, transparent 1px),
      #f5f0e6;
    background-size: 44px 44px;
  }

  .course-page {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 34px clamp(42px, 6vw, 112px) 90px;
    box-sizing: border-box;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 6px 0 42px;
    color: rgba(27, 23, 17, 0.55);
    font-size: 0.9rem;
  }

  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: #1f1a13;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .course-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 64px;
    align-items: end;
    padding-bottom: 38px;
    margin-bottom: 10px;
    border-bottom: 1px solid rgba(31, 26, 19, 0.23);
  }

  .semester {
    display: inline-block;
    margin: 0 0 18px;
    padding: 4px 9px;
    border: 1px solid rgba(132, 91, 34, 0.24);
    border-radius: 999px;
    color: #7c5520;
    background: rgba(255, 248, 235, 0.58);
    font-size: 0.73rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .course-hero h1 {
    margin: 0;
    color: #101827;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(4.1rem, 8vw, 7.4rem);
    line-height: 0.92;
    letter-spacing: -0.07em;
    font-weight: 500;
  }

  .course-title > p:not(.semester) {
    max-width: 720px;
    margin: 20px 0 0;
    color: rgba(31, 26, 19, 0.7);
    font-size: 1.12rem;
    line-height: 1.65;
  }

  .course-meta {
    display: flex;
    gap: 18px;
    min-width: 270px;
    padding-bottom: 8px;
  }

  .course-meta div {
    min-width: 112px;
    padding-top: 14px;
    border-top: 1px solid rgba(31, 26, 19, 0.22);
  }

  .course-meta strong {
    display: block;
    color: #101827;
    font-size: 1.38rem;
    line-height: 1;
  }

  .course-meta span {
    display: block;
    margin-top: 7px;
    color: rgba(31, 26, 19, 0.53);
    font-size: 0.8rem;
  }

  .archive-list {
    display: grid;
  }

  .archive-section {
    display: grid;
    grid-template-columns: minmax(190px, 220px) minmax(0, 1fr);
    gap: clamp(34px, 4vw, 58px);
    padding: 36px 0;
    border-bottom: 1px solid rgba(31, 26, 19, 0.14);
  }

  .section-head {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 0;
    align-self: start;
  }

  .section-number {
    padding-top: 5px;
    color: #9a6a2f;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
  }

  .section-head h2 {
    margin: 0;
    color: #15130f;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.75rem;
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.035em;
  }

  .section-head p {
    margin: 9px 0 0;
    color: rgba(31, 26, 19, 0.5);
    font-size: 0.86rem;
  }

  .document-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: 34px;
  }

  .document-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid rgba(31, 26, 19, 0.1);
    color: #15130f;
    text-decoration: none;
  }

  .document-row::after {
    content: "↗";
    position: absolute;
    right: 0;
    opacity: 0;
    transform: translateX(-4px);
    color: rgba(31, 26, 19, 0.5);
    transition: opacity 0.14s ease, transform 0.14s ease;
  }

  .document-row:hover {
    border-bottom-color: rgba(31, 26, 19, 0.34);
  }

  .document-row:hover::after {
    opacity: 1;
    transform: translateX(0);
  }

  .document-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding-right: 20px;
    font-size: 1rem;
    font-weight: 560;
    letter-spacing: -0.01em;
  }

  .document-detail {
    padding-right: 18px;
    color: rgba(31, 26, 19, 0.44);
    font-size: 0.76rem;
    text-transform: lowercase;
    white-space: nowrap;
  }

  @media (max-width: 1100px) {
    .document-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .course-page {
      padding-inline: 24px;
    }

    .course-hero {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .course-meta {
      min-width: 0;
      max-width: 330px;
    }

    .archive-section {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .section-head {
      grid-template-columns: 42px minmax(0, 1fr);
    }
  }

  @media (max-width: 620px) {
    .course-hero h1 {
      font-size: 3.3rem;
    }

    .course-meta {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .document-list {
      grid-template-columns: 1fr;
    }

    .document-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .document-detail {
      padding-right: 0;
    }
  }
</style>
