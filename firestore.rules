rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for courses, subjects, chapters
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth.uid == 'iw4t9QYWJgeWiCwKbiPTlyrSBlk2'; // Only admin can write
    }
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if request.auth.uid == 'iw4t9QYWJgeWiCwKbiPTlyrSBlk2'; // Only admin can write
    }
    match /chapters/{chapterId} {
      allow read: if true;
      allow write: if request.auth.uid == 'iw4t9QYWJgeWiCwKbiPTlyrSBlk2'; // Only admin can write
    }

    // Rules for user profiles
    match /user-profiles/{userId} {
      // Allow a user to create, read, and update their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for contact messages
    match /contact-messages/{messageId} {
        // Allow anyone to create a message (e.g. for a contact form)
        allow create: if true;
        // Only admin can read/delete them
        allow read, delete: if request.auth.uid == 'iw4t9QYWJgeWiCwKbiPTlyrSBlk2';
    }
  }
}