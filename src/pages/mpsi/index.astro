---
import Base from '../../layouts/Base.astro';
import { mpsiMathsCategories, mpsiMathsDocumentCount } from '../../data/mpsi-maths';
---
<Base title="MPSI Mathématiques — Jean-Baptiste-Corot — 2024/2025">
  <main class="main-grid">
    <section>
      <h1 class="main-title">MPSI Mathématiques — Jean-Baptiste-Corot — 2024/2025</h1>

      <p class="lede">
        Archive mathématique uniquement : cours, TD, devoirs, programmes de colles et corrections issus du dossier webMathematiques du RAR MPSI.
      </p>

      <div class="notice">
        <b>{mpsiMathsDocumentCount} documents indexés.</b> Choisis une catégorie : chaque page n’affiche ensuite que les documents de cette catégorie.
      </div>

      <section class="section">
        <div class="section-line-heading">
          <h2>Catégories</h2>
        </div>

        <div class="subject-register">
          {mpsiMathsCategories.map((category) => (
            <a class="subject-entry" href={`/mpsi/${category.id}/`}>
              <span class="entry-title">{category.title}</span>
              <span class="entry-prof">{category.documents.length} document(s)</span>
              <span class="entry-desc">{category.description}</span>
            </a>
          ))}
        </div>
      </section>
    </section>

    <aside class="sidebar">
      <div class="box">
        <h2>Navigation MPSI</h2>
        <ul class="compact-list">
          {mpsiMathsCategories.map((category) => (
            <li>
              <a href={`/mpsi/${category.id}/`}><b>{category.title}</b></a><br />
              <span class="small">{category.documents.length} document(s)</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="box">
        <h2>Retour</h2>
        <p class="small">
          <a href="/">← revenir à l’accueil</a>
        </p>
      </div>
    </aside>
  </main>
</Base>
