---
import Base from '../../layouts/Base.astro';
import { mpsiMathsCategories } from '../../data/mpsi-maths';

export function getStaticPaths() {
  return mpsiMathsCategories.map((category) => ({
    params: { category: category.id },
    props: { category },
  }));
}

const { category } = Astro.props;

function shortDocumentTitle(doc) {
  const raw = doc.originalPath.split('/').pop()?.replace(/\.pdf$/i, '') ?? doc.title;

  return raw
    .replace(/[_\s-]+(?:appr|approfondissement)$/i, '')
    .replace(/[_\s-]+(?:corr|corrige|corrigé)$/i, '')
    .replaceAll('_', ' ')
    .replaceAll('-', ' ')
    .replace(/\s+/g, ' ')
    .trim();
}
---
<Base title={`${category.title} — MPSI Mathématiques`}>
  <main class="mpsi-category-page">
    <header class="mpsi-archive-header">
      <h1>{category.title}</h1>
      <p>{category.documents.length} documents · MPSI Mathématiques · Jean-Baptiste-Corot · 2024/2025</p>
    </header>

    <section class="mpsi-doc-grid" aria-label={`Documents MPSI — ${category.title}`}>
      {category.documents.map((doc) => (
        <a class="mpsi-doc-card" href={doc.path} target="_blank" rel="noopener noreferrer">
          <span class="mpsi-doc-title">{shortDocumentTitle(doc)}</span>
          <span class="mpsi-doc-meta">{doc.originalPath}</span>
        </a>
      ))}
    </section>
  </main>
</Base>

<style>
  :global(.site:has(.mpsi-category-page)) {
    width: min(1760px, calc(100vw - 96px));
  }

  .mpsi-category-page {
    width: 100%;
    max-width: none;
    margin: 0;
    padding-top: 26px;
  }

  .mpsi-archive-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 36px;
    margin-bottom: 18px;
    padding-bottom: 18px;
    border-bottom: 2px solid var(--ink);
  }

  .mpsi-archive-header h1 {
    margin: 0;
    max-width: none;
    font-size: clamp(62px, 8vw, 122px);
    line-height: 0.86;
    letter-spacing: -0.065em;
    font-weight: 500;
    overflow-wrap: anywhere;
  }

  .mpsi-archive-header p {
    margin: 0 0 10px;
    max-width: 620px;
    color: var(--muted);
    font-family: Arial, Helvetica, sans-serif;
    font-size: 13px;
    line-height: 1.35;
    text-align: right;
  }

  .mpsi-doc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 10px;
    margin-top: 16px;
    align-items: stretch;
  }

  .mpsi-doc-card {
    display: grid;
    grid-template-columns: 76px minmax(0, 1fr);
    gap: 10px;
    align-items: baseline;
    min-height: 54px;
    border: 1px solid var(--line);
    background: rgba(255,253,246,0.74);
    padding: 9px 10px;
    color: var(--ink);
    text-decoration: none;
  }

  .mpsi-doc-card:hover {
    background: var(--paper);
    border-color: var(--ink);
  }

  .mpsi-doc-title {
    color: var(--link);
    font-size: 20px;
    line-height: 1;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
    overflow-wrap: anywhere;
  }

  .mpsi-doc-meta {
    font-family: Arial, Helvetica, sans-serif;
    color: var(--muted);
    font-size: 11px;
    line-height: 1.25;
    overflow-wrap: anywhere;
  }

  @media (min-width: 1500px) {
    .mpsi-doc-grid {
      grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
    }
  }

  @media (max-width: 900px) {
    :global(.site:has(.mpsi-category-page)) {
      width: calc(100vw - 24px);
    }

    .mpsi-archive-header {
      display: block;
    }

    .mpsi-archive-header h1 {
      font-size: clamp(42px, 12vw, 54px);
      line-height: 0.92;
      letter-spacing: -0.05em;
      max-width: 100%;
    }

    .mpsi-archive-header p {
      max-width: none;
      margin-top: 10px;
      text-align: left;
    }

    .mpsi-doc-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      grid-auto-flow: row;
    }

    .mpsi-doc-card {
      display: flex;
      align-items: flex-start;
      justify-content: flex-start;
      height: 72px;
      min-height: 72px;
      padding: 10px;
    }

    .mpsi-doc-title {
      display: block;
      width: 100%;
      font-size: 18px;
      line-height: 0.96;
    }

    .mpsi-doc-meta {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .mpsi-archive-header h1 {
      font-size: 42px;
      letter-spacing: -0.045em;
    }

    .mpsi-doc-card {
      height: 68px;
      min-height: 68px;
    }
  }
</style>
