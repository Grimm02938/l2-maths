---
import Base from '../../layouts/Base.astro';
import { mpsiMathsCategories } from '../../data/mpsi-maths';

export function getStaticPaths() {
  return mpsiMathsCategories.map((category) => ({
    params: { category: category.id },
    props: { category },
  }));
}

const { category } = Astro.props;
const density = category.documents.length >= 24 ? 'many' : category.documents.length >= 12 ? 'medium' : 'few';
---
<Base title={`${category.title} — MPSI Mathématiques`}>
  <main class={`subject-main mpsi-category-page ${density}`}>
    <header class="mpsi-archive-header">
      <div>
        <h1>{category.title}</h1>
        <p>MPSI Mathématiques — Jean-Baptiste-Corot — 2024/2025</p>
      </div>
      <strong>{category.documents.length} documents</strong>
    </header>

    <section class="mpsi-doc-columns" aria-label={`Documents MPSI — ${category.title}`}>
      {category.documents.map((doc) => (
        <a class="mpsi-doc-card" href={doc.path} target="_blank" rel="noopener noreferrer">
          <span class="mpsi-doc-title">{doc.title}</span>
          <span class="mpsi-doc-meta">{doc.originalPath}</span>
        </a>
      ))}
    </section>
  </main>
</Base>

<style>
  .mpsi-category-page {
    width: 100%;
    max-width: none;
    margin: 0;
    padding-top: 26px;
  }

  .mpsi-archive-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 36px;
    margin-bottom: 18px;
    padding-bottom: 18px;
    border-bottom: 2px solid var(--ink);
  }

  .mpsi-archive-header h1 {
    margin: 0;
    max-width: none;
    font-size: clamp(62px, 8vw, 122px);
    line-height: 0.86;
    letter-spacing: -0.065em;
    font-weight: 500;
  }

  .mpsi-archive-header p {
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 15px;
  }

  .mpsi-archive-header strong {
    margin-bottom: 10px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  .mpsi-doc-columns {
    column-gap: 16px;
    column-rule: 1px solid rgba(189, 177, 160, 0.55);
    margin-top: 16px;
  }

  .mpsi-category-page.many .mpsi-doc-columns { column-count: 3; }
  .mpsi-category-page.medium .mpsi-doc-columns { column-count: 2; }
  .mpsi-category-page.few .mpsi-doc-columns { column-count: 2; }

  .mpsi-doc-card {
    display: grid;
    grid-template-columns: 92px minmax(0, 1fr);
    gap: 12px;
    align-items: baseline;
    width: 100%;
    min-height: 52px;
    margin: 0 0 9px;
    break-inside: avoid;
    border: 1px solid var(--line);
    background: rgba(255,253,246,0.74);
    padding: 9px 10px;
    color: var(--ink);
    text-decoration: none;
  }

  .mpsi-doc-card:hover {
    background: var(--paper);
    border-color: var(--ink);
  }

  .mpsi-doc-title {
    color: var(--link);
    font-size: 20px;
    line-height: 1;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
    overflow-wrap: anywhere;
  }

  .mpsi-doc-meta {
    font-family: Arial, Helvetica, sans-serif;
    color: var(--muted);
    font-size: 11px;
    line-height: 1.25;
    overflow-wrap: anywhere;
  }

  @media (min-width: 1500px) {
    .mpsi-category-page.many .mpsi-doc-columns { column-count: 4; }
    .mpsi-category-page.medium .mpsi-doc-columns { column-count: 3; }
  }

  @media (max-width: 900px) {
    .mpsi-archive-header {
      display: block;
    }

    .mpsi-archive-header strong {
      display: block;
      margin-top: 10px;
    }

    .mpsi-doc-columns,
    .mpsi-category-page.many .mpsi-doc-columns,
    .mpsi-category-page.medium .mpsi-doc-columns,
    .mpsi-category-page.few .mpsi-doc-columns {
      column-count: 2;
      column-gap: 8px;
      column-rule: 0;
    }

    .mpsi-doc-card {
      display: block;
      min-height: 62px;
      padding: 8px;
      margin-bottom: 8px;
    }

    .mpsi-doc-title {
      display: block;
      font-size: 18px;
    }

    .mpsi-doc-meta {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .mpsi-archive-header h1 {
      font-size: 52px;
    }
  }
</style>
