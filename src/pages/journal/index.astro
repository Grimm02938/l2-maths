---
import Base from '../../layouts/Base.astro';
---
<Base title="Journal — Adame Abdelmoula">
  <main class="journal-main">
    <section class="journal-hero">
      <p class="journal-kicker">Journal de bord privé</p>
      <h1>Journal.</h1>
      <p>
        Un espace simple pour écrire à chaud : idées, doutes, décisions, fragments. Les messages restent dans le navigateur grâce au stockage local de l’appareil.
      </p>
    </section>

    <section class="journal-compose" aria-label="Écrire une entrée">
      <textarea id="journal-input" placeholder="Écris ici. Une pensée, une décision, une phrase qui doit rester quelque part..."></textarea>
      <div class="journal-actions">
        <button id="save-entry" type="button">Ajouter au journal</button>
        <button id="export-entries" type="button" class="secondary">Exporter</button>
        <button id="clear-entries" type="button" class="ghost">Tout effacer</button>
      </div>
      <p class="journal-note">Ce journal est local : il vit sur cet appareil. L’export permet d’en garder une copie.</p>
    </section>

    <section class="journal-thread" aria-label="Messages du journal">
      <div id="journal-empty" class="journal-empty">
        Aucun message pour l’instant. Commence par une ligne vraie, même courte.
      </div>
      <div id="journal-list"></div>
    </section>
  </main>
</Base>

<script>
  const STORAGE_KEY = 'adame-local-journal-v1';
  const input = document.querySelector('#journal-input');
  const saveButton = document.querySelector('#save-entry');
  const exportButton = document.querySelector('#export-entries');
  const clearButton = document.querySelector('#clear-entries');
  const list = document.querySelector('#journal-list');
  const empty = document.querySelector('#journal-empty');

  function readEntries() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function writeEntries(entries) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
  }

  function formatDate(iso) {
    return new Intl.DateTimeFormat('fr-FR', {
      dateStyle: 'medium',
      timeStyle: 'short',
    }).format(new Date(iso));
  }

  function render() {
    const entries = readEntries().sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
    list.innerHTML = '';
    empty.hidden = entries.length > 0;

    for (const entry of entries) {
      const article = document.createElement('article');
      article.className = 'journal-message';

      const time = document.createElement('time');
      time.dateTime = entry.createdAt;
      time.textContent = formatDate(entry.createdAt);

      const body = document.createElement('p');
      body.textContent = entry.text;

      const remove = document.createElement('button');
      remove.type = 'button';
      remove.className = 'remove-entry';
      remove.textContent = 'supprimer';
      remove.addEventListener('click', () => {
        const next = readEntries().filter((item) => item.id !== entry.id);
        writeEntries(next);
        render();
      });

      article.append(time, body, remove);
      list.append(article);
    }
  }

  saveButton?.addEventListener('click', () => {
    const text = input.value.trim();
    if (!text) return;

    const entries = readEntries();
    entries.push({
      id: crypto.randomUUID ? crypto.randomUUID() : String(Date.now()),
      text,
      createdAt: new Date().toISOString(),
    });
    writeEntries(entries);
    input.value = '';
    render();
  });

  input?.addEventListener('keydown', (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key === 'Enter') {
      saveButton.click();
    }
  });

  exportButton?.addEventListener('click', () => {
    const blob = new Blob([JSON.stringify(readEntries(), null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `journal-adame-${new Date().toISOString().slice(0, 10)}.json`;
    link.click();
    URL.revokeObjectURL(url);
  });

  clearButton?.addEventListener('click', () => {
    if (!confirm('Effacer toutes les entrées locales de ce journal ?')) return;
    writeEntries([]);
    render();
  });

  render();
</script>

<style>
  .journal-main {
    max-width: 1180px;
    margin: 0;
    padding: 54px 32px 96px 96px;
  }

  .journal-hero {
    max-width: 900px;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 28px;
  }

  .journal-kicker {
    margin: 0 0 10px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .journal-hero h1 {
    margin: 0;
    font-size: clamp(58px, 9vw, 128px);
    line-height: 0.86;
    letter-spacing: -0.07em;
    font-weight: 500;
  }

  .journal-hero p {
    max-width: 760px;
    margin: 22px 0 0;
    font-size: 19px;
    color: #312820;
  }

  .journal-compose {
    max-width: 900px;
    margin-top: 28px;
    border: 1px solid var(--line);
    background: rgba(255,253,246,0.72);
    padding: 14px;
  }

  .journal-compose textarea {
    width: 100%;
    min-height: 150px;
    resize: vertical;
    border: 0;
    border-bottom: 1px solid var(--line);
    background: transparent;
    padding: 10px 4px 14px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 20px;
    line-height: 1.45;
    color: var(--ink);
    outline: none;
  }

  .journal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .journal-actions button,
  .remove-entry {
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    padding: 7px 10px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    cursor: pointer;
  }

  .journal-actions .secondary {
    background: var(--paper);
    color: var(--ink);
  }

  .journal-actions .ghost,
  .remove-entry {
    border-color: var(--line);
    background: transparent;
    color: var(--muted);
  }

  .journal-note {
    margin: 10px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .journal-thread {
    max-width: 900px;
    margin-top: 30px;
  }

  .journal-empty {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 18px 0;
    color: var(--muted);
  }

  .journal-message {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr) auto;
    gap: 22px;
    align-items: start;
    border-top: 1px solid var(--line);
    padding: 18px 0;
  }

  .journal-message:last-child {
    border-bottom: 1px solid var(--line);
  }

  .journal-message time {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    color: var(--muted);
  }

  .journal-message p {
    margin: 0;
    white-space: pre-wrap;
    font-size: 18px;
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .journal-main {
      padding: 36px 18px 74px;
    }

    .journal-message {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
