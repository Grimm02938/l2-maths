---
import Base from '../../layouts/Base.astro';
---
<Base title="Préparation magistère — Archives mathématiques">
  <main class="main-grid">
    <section>
      <p class="small"><a href="/">← retour à l'accueil</a></p>
      <h1 class="main-title">Préparation magistère.</h1>
      <p class="lede">
        Cette page servira à séparer les ressources de consolidation L2 des ressources plus ambitieuses : exercices avancés, livres, problèmes longs, lectures hors programme.
      </p>

      <section class="section">
        <h2>Chantiers</h2>
        <table class="archive-table">
          <thead>
            <tr>
              <th>Bloc</th>
              <th>Objectif</th>
              <th>Statut</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>ALG</td>
              <td>reprendre réduction, dualité, formes bilinéaires, groupes</td>
              <td><span class="tag">à ouvrir</span></td>
            </tr>
            <tr>
              <td>ANA</td>
              <td>solidifier suites, séries, intégrales, espaces métriques</td>
              <td><span class="tag">à ouvrir</span></td>
            </tr>
            <tr>
              <td>TOP</td>
              <td>exemples et contre-exemples, compacité, connexité</td>
              <td><span class="tag">à ouvrir</span></td>
            </tr>
            <tr>
              <td>PROB</td>
              <td>convergences, conditionnement, variables classiques</td>
              <td><span class="tag">à ouvrir</span></td>
            </tr>
          </tbody>
        </table>
      </section>
    </section>

    <aside class="sidebar">
      <div class="box">
        <h2>Principe</h2>
        <p class="small">Ne pas mélanger l'archive L2 avec la préparation avancée. La L2 est le socle ; le magistère est l'extension.</p>
      </div>
    </aside>
  </main>
</Base>
