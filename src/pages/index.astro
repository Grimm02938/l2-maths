---
import Base from '../layouts/Base.astro';
import { subjects, logbook, externalSeeds } from '../data/archive';

const totalChapters = subjects.flatMap((subject) => subject.chapters).length;
const totalResources = subjects.flatMap((subject) => subject.chapters.flatMap((chapter) => chapter.resources)).length;
const s1Subjects = subjects.filter((subject) => subject.semester === 'S1' || subject.semester === 'Annuel');
const s2Subjects = subjects.filter((subject) => subject.semester === 'S2' || subject.semester === 'Annuel');
---
<Base title="Archives mathématiques — Adame Abdelmoula">
  <main class="main-grid">
    <section>
      <p class="small">version expérimentale / Astro / HTML sobre</p>
      <h1 class="main-title">Archives mathématiques personnelles.</h1>
      <p class="lede">
        Une page de travail simple, faite pour retrouver vite les cours, TD, annales et corrections. Pas un portfolio. Pas un dashboard. Une table d'archives qui doit rester lisible dans dix ans.
      </p>

      <div class="notice">
        <b>Principe :</b> chaque matière a une page. Chaque chapitre indique ce qui existe, ce qui manque, et ce qui doit être repris. Les liens PDF sont directs quand le fichier existe.
      </div>

      <section class="section semester-switcher" id="licence-2">
        <input type="radio" id="semestre-1" name="semestre" checked />
        <input type="radio" id="semestre-2" name="semestre" />

        <div class="section-line-heading">
          <h2>Licence 2 — 2025/2026</h2>
          <div class="semester-control" aria-label="Choix du semestre">
            <label for="semestre-1">Semestre 1</label>
            <label for="semestre-2">Semestre 2</label>
          </div>
        </div>

        <div class="subject-register semester-panel s1-panel" aria-label="Registre des matières du semestre 1">
          {s1Subjects.map((subject) => {
            const resources = subject.chapters.flatMap((chapter) => chapter.resources).length;
            return (
              <a class="subject-entry" href={`/l2/${subject.slug}/`}>
                <span class="entry-main">
                  <span class="entry-title">{subject.title}</span>
                  <span class="entry-prof">Prof. {subject.professor}</span>
                  <span class="entry-desc">{subject.description}</span>
                </span>
                <span class="entry-stats">
                  <span>{subject.status}</span>
                  <span>{subject.chapters.length} ch.</span>
                  <span>{resources} ress.</span>
                </span>
                <span class="entry-open">→</span>
              </a>
            );
          })}
        </div>

        <div class="subject-register semester-panel s2-panel" aria-label="Registre des matières du semestre 2">
          {s2Subjects.map((subject) => {
            const resources = subject.chapters.flatMap((chapter) => chapter.resources).length;
            return (
              <a class="subject-entry" href={`/l2/${subject.slug}/`}>
                <span class="entry-main">
                  <span class="entry-title">{subject.title}</span>
                  <span class="entry-prof">Prof. {subject.professor}</span>
                  <span class="entry-desc">{subject.description}</span>
                </span>
                <span class="entry-stats">
                  <span>{subject.status}</span>
                  <span>{subject.chapters.length} ch.</span>
                  <span>{resources} ress.</span>
                </span>
                <span class="entry-open">→</span>
              </a>
            );
          })}
        </div>
      </section>

      <section class="section">
        <h2>Carnet récent</h2>
        <ul class="link-list">
          {logbook.map((entry) => (
            <li>
              <b>{entry.date}</b> — <a href="/carnet/">{entry.title}</a><br />
              <span class="small">{entry.text}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="section">
        <h2>Arborescence prévue</h2>
        <pre class="directory">public/pdf/
├── analyse/
│   ├── cours.pdf
│   ├── td.pdf
│   └── corriges/
├── algebre-lineaire/
├── topologie/
├── probabilites/
└── annales/

src/pages/
├── index.astro
├── l2/[slug].astro
├── carnet/index.astro
└── magistere/index.astro</pre>
      </section>
    </section>

    <aside class="sidebar">
      <div class="box">
        <h2>État de l'archive</h2>
        <ul class="compact-list">
          <li>{subjects.length} matières</li>
          <li>{totalChapters} chapitres</li>
          <li>{totalResources} entrées de ressources</li>
          <li>déploiement : Firebase Hosting</li>
        </ul>
      </div>

      <div class="box">
        <h2>À faire</h2>
        <ul class="compact-list">
          <li>remplacer les faux liens par les vrais PDF</li>
          <li>ajouter les corrigés personnels</li>
          <li>classer les annales</li>
          <li>rédiger les notes d'erreurs</li>
        </ul>
      </div>

      <div class="box">
        <h2>Inspirations structurelles</h2>
        <ul class="compact-list">
          {externalSeeds.map((seed) => (
            <li><b>{seed.label}</b><br /><span class="small">{seed.text}</span></li>
          ))}
        </ul>
      </div>
    </aside>
  </main>
</Base>
