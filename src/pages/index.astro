---
import Base from '../layouts/Base.astro';
import { subjects, logbook } from '../data/archive';
import { mpsiMathsCategories, mpsiMathsDocumentCount } from '../data/mpsi-maths';

const s1Subjects = subjects.filter((subject) => subject.semester === 'S1' || subject.semester === 'Annuel');
const s2Subjects = subjects.filter((subject) => subject.semester === 'S2' || subject.semester === 'Annuel');
---
<Base title="Archives mathématiques — Adame Abdelmoula">
  <main class="main-grid">
    <section>
      <h1 class="main-title">Archives mathématiques personnelles.</h1>
      <p class="lede">
        Une archive de Licence 2 Mathématiques à Paris-Saclay, faite pour retrouver vite les cours, TD, annales et corrections. Une table de travail lisible, pensée pour garder une trace durable du semestre.
      </p>

      <div class="notice">
        <b>Principe :</b> la L2 reste le cœur actif du site. Le bloc MPSI Mathématiques — Jean-Baptiste-Corot — 2024/2025 est séparé, strictement mathématique, et indexe {mpsiMathsDocumentCount} documents.
      </div>

      <section class="section semester-switcher" id="licence-2">
        <input type="radio" id="semestre-1" name="semestre" checked />
        <input type="radio" id="semestre-2" name="semestre" />

        <div class="section-line-heading">
          <h2>Licence 2 Mathématiques — Paris-Saclay — 2025/2026</h2>
          <div class="semester-control" aria-label="Choix du semestre">
            <label for="semestre-1">Semestre 1</label>
            <label for="semestre-2">Semestre 2</label>
          </div>
        </div>

        <div class="subject-register semester-panel s1-panel" aria-label="Registre des matières du semestre 1">
          {s1Subjects.map((subject) => (
            <a class="subject-entry" href={`/l2/${subject.slug}/`}>
              <span class="entry-title">{subject.title}</span>
              <span class="entry-prof">Prof. {subject.professor}</span>
              <span class="entry-desc">{subject.description}</span>
            </a>
          ))}
        </div>

        <div class="subject-register semester-panel s2-panel" aria-label="Registre des matières du semestre 2">
          {s2Subjects.map((subject) => (
            <a class="subject-entry" href={`/l2/${subject.slug}/`}>
              <span class="entry-title">{subject.title}</span>
              <span class="entry-prof">Prof. {subject.professor}</span>
              <span class="entry-desc">{subject.description}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section" id="mpsi-maths">
        <div class="section-line-heading">
          <h2>MPSI Mathématiques — Jean-Baptiste-Corot — 2024/2025</h2>
        </div>

        <div class="notice">
          <b>Archive mathématique uniquement :</b> {mpsiMathsDocumentCount} documents indexés depuis le dossier webMathematiques du RAR MPSI. Aucun document de physique n’est intégré.
        </div>

        <div class="subject-register">
          {mpsiMathsCategories.map((category) => (
            <a class="subject-entry" href={`/mpsi/${category.id}/`}>
              <span class="entry-title">{category.title}</span>
              <span class="entry-prof">{category.documents.length} document(s)</span>
              <span class="entry-desc">{category.description}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>Carnet récent</h2>
        <ul class="link-list">
          {logbook.map((entry) => (
            <li>
              <b>{entry.date}</b> — <a href="/carnet/">{entry.title}</a><br />
              <span class="small">{entry.text}</span>
            </li>
          ))}
        </ul>
      </section>
    </section>

    <aside class="sidebar">
      <div class="box">
        <h2>Deux corpus</h2>
        <ul class="compact-list">
          <li><b>Licence 2 Mathématiques</b><br /><span class="small">Paris-Saclay — 2025/2026</span></li>
          <li><b>MPSI Mathématiques</b><br /><span class="small">Jean-Baptiste-Corot — 2024/2025 · {mpsiMathsDocumentCount} documents</span></li>
        </ul>
      </div>

      <div class="box">
        <h2>Inspirations structurelles</h2>
        <ul class="compact-list">
          <li><b>Sites d’enseignants</b></li>
          <li><b>WebGirand</b><br /><span class="small">site d’Arnaud Girand</span></li>
          <li><b>vb.webprepa.eu</b><br /><span class="small">site de Joël Sagayaradje</span></li>
        </ul>
      </div>

      <div class="box">
        <h2>Nota bene</h2>
        <p class="small">
          Remerciements à Joël Sagayaradje pour ses notes personnelles, amicalement partagées, et pour son site vb.webprepa.eu.
        </p>
      </div>

      <nav class="floating-folder-tree" aria-label="Arborescence du site">
        <a class="folder-line root-folder" href="/">📁 l2-maths.web.app</a>
        <div class="folder-children">
          <a class="folder-line corpus-folder" href="/#licence-2">📁 Licence 2 Mathématiques</a>
          <div class="folder-children thin">
            <span class="folder-line semester-folder">📁 Semestre 1</span>
            <div class="folder-children thinner">
              {s1Subjects.map((subject) => (
                <a class="folder-line leaf" href={`/l2/${subject.slug}/`}>📂 {subject.title}</a>
              ))}
            </div>
            <span class="folder-line semester-folder">📁 Semestre 2</span>
            <div class="folder-children thinner">
              {s2Subjects.map((subject) => (
                <a class="folder-line leaf" href={`/l2/${subject.slug}/`}>📂 {subject.title}</a>
              ))}
            </div>
          </div>

          <a class="folder-line corpus-folder" href="/mpsi/">📁 MPSI Mathématiques</a>
          <div class="folder-children thin">
            <a class="folder-line leaf" href="/mpsi/cours/">📂 Cours</a>
            <a class="folder-line leaf" href="/mpsi/td/">📂 TD</a>
            <a class="folder-line leaf" href="/mpsi/td-corriges/">📂 Corrigés TD</a>
            <a class="folder-line leaf" href="/mpsi/ds/">📂 DS</a>
            <a class="folder-line leaf" href="/mpsi/dm-dl/">📂 DM / DL</a>
            <a class="folder-line leaf" href="/mpsi/colles/">📂 Colles</a>
          </div>
          <a class="folder-line corpus-folder" href="/carnet/">📁 Carnet</a>
          <a class="folder-line corpus-folder" href="/journal/">📁 Journal</a>
        </div>
      </nav>
    </aside>
  </main>
</Base>

<style>
  .floating-folder-tree {
    margin: 22px 0 0 2px;
    padding: 2px 0 4px;
    background: transparent;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    font-size: 12px;
    line-height: 1.28;
  }

  .folder-line {
    position: relative;
    display: block;
    padding: 4px 0 4px 4px;
    color: var(--ink);
    text-decoration: none;
    white-space: normal;
  }

  .folder-line:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .root-folder {
    display: inline-block;
    margin-bottom: 6px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .corpus-folder,
  .semester-folder {
    font-weight: 600;
  }

  .leaf {
    color: #2c2925;
  }

  .folder-children {
    position: relative;
    margin-left: 13px;
    padding-left: 12px;
    border-left: 1px solid rgba(107,98,87,0.48);
  }

  .folder-children.thin {
    margin-left: 10px;
    padding-left: 10px;
  }

  .folder-children.thinner {
    margin-left: 9px;
    padding-left: 9px;
    opacity: 0.96;
  }

  .folder-children > .folder-line::before {
    content: '';
    position: absolute;
    left: -12px;
    top: 13px;
    width: 10px;
    border-top: 1px solid rgba(107,98,87,0.48);
  }

  .folder-children.thin > .folder-line::before {
    left: -10px;
    width: 8px;
  }

  .folder-children.thinner > .folder-line::before {
    left: -9px;
    width: 7px;
  }

  @media (max-width: 820px) {
    .floating-folder-tree {
      margin-top: 18px;
      font-size: 12px;
    }
  }
</style>
