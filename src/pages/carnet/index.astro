---
import Base from '../../layouts/Base.astro';
import { logbook } from '../../data/archive';
---
<Base title="Carnet de travail — Archives mathématiques">
  <main class="main-grid">
    <section>
      <p class="small"><a href="/">← retour à l'accueil</a></p>
      <h1 class="main-title">Carnet de travail.</h1>
      <p class="lede">
        Notes courtes, dettes, erreurs fréquentes, méthodes à stabiliser. Cette partie n'est pas faite pour être parfaite : elle sert à garder la trace du travail réel.
      </p>

      <section class="section">
        <h2>Entrées</h2>
        <table class="archive-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Note</th>
              <th>Statut</th>
            </tr>
          </thead>
          <tbody>
            {logbook.map((entry) => (
              <tr>
                <td>{entry.date}</td>
                <td><b>{entry.title}</b><br /><span class="small">{entry.text}</span></td>
                <td><span class="tag">working</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    </section>

    <aside class="sidebar">
      <div class="box">
        <h2>Rubriques prévues</h2>
        <ul class="compact-list">
          <li>erreurs classiques</li>
          <li>méthodes de démonstration</li>
          <li>questions ouvertes</li>
          <li>résumés de livres</li>
        </ul>
      </div>
    </aside>
  </main>
</Base>
