---
import Base from '../../layouts/Base.astro';
import { logbook } from '../../data/archive';
import { generatedLogbook } from '../../data/generated-carnet';

const entries = [...generatedLogbook, ...logbook];

function formatDate(date) {
  return new Date(`${date}T12:00:00`).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---
<Base title="Carnet — Archives mathématiques">
  <main class="carnet-main">
    <section class="carnet-board" aria-label="Carnet de travail">
      <header class="carnet-board-header">
        <div>
          <p class="carnet-kicker">Carnet de travail</p>
          <h1>Chronique de l’archive</h1>
        </div>
        <p>
          Les ajouts importants du site, réécrits comme une trace de travail plutôt qu’un journal technique.
        </p>
      </header>

      <div class="carnet-grid">
        {entries.map((entry) => (
          <article class="carnet-card">
            <time datetime={entry.date}>{formatDate(entry.date)}</time>
            <div>
              <h2>{entry.title}</h2>
              <p>{entry.text}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Base>

<style>
  .carnet-main {
    max-width: none;
    margin: 0;
    padding: 42px 0 90px;
  }

  .carnet-board {
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    padding: 22px 0 28px;
  }

  .carnet-board-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 36px;
    align-items: end;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--line);
  }

  .carnet-kicker {
    margin: 0 0 8px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .carnet-board-header h1 {
    margin: 0;
    font-size: clamp(34px, 5vw, 68px);
    line-height: 0.94;
    letter-spacing: -0.055em;
    font-weight: 500;
  }

  .carnet-board-header > p {
    margin: 0 0 6px;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.5;
  }

  .carnet-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .carnet-card {
    min-height: 168px;
    display: grid;
    grid-template-columns: 112px minmax(0, 1fr);
    gap: 18px;
    border: 1px solid var(--line);
    background: rgba(255,253,246,0.72);
    padding: 14px 16px;
  }

  .carnet-card time {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.35;
  }

  .carnet-card h2 {
    margin: 0 0 10px;
    font-size: 23px;
    line-height: 1.04;
    letter-spacing: -0.025em;
  }

  .carnet-card p {
    margin: 0;
    color: #51483e;
    font-size: 15px;
    line-height: 1.55;
  }

  @media (min-width: 1400px) {
    .carnet-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .carnet-board-header {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .carnet-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .carnet-main {
      padding: 28px 0 72px;
    }

    .carnet-board {
      padding-top: 18px;
    }

    .carnet-board-header h1 {
      font-size: 44px;
    }

    .carnet-card {
      grid-template-columns: 1fr;
      gap: 9px;
      min-height: auto;
      padding: 13px 14px;
    }
  }
</style>
